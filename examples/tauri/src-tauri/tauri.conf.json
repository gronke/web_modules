{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "web-modules-tauri",
  "version": "0.1.0",
  "identifier": "rs.webmodules.example",
  "build": {
    "beforeDevCommand": "cargo run --manifest-path src-tauri/Cargo.toml --bin dev-server",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "cargo run --manifest-path src-tauri/Cargo.toml --bin dev-server -- bake dist",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "web-modules · Tauri",
        "width": 900,
        "height": 700,
        "resizable": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; style-src 'self' 'unsafe-inline'; img-src 'self' data:; connect-src 'self' ipc: http://ipc.localhost"
    }
  },
  "bundle": {
    "active": false,
    "icon": ["icons/icon.png"]
  }
}
