{
  // Type-checks the TypeScript sources that web-modules transforms with oxc. oxc
  // strips types without checking them, so this `tsc --noEmit` pass is what catches
  // type errors. `isolatedModules` mirrors oxc's file-by-file transform (rejecting
  // constructs a single-file transform can't handle); `useDefineForClassFields:false`
  // matches both oxc's emit and Lit's decorator-free `static properties` pattern.
  "compilerOptions": {
    "target": "ES2022",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "lib": ["ES2022", "DOM", "DOM.Iterable"],
    "strict": true,
    "noEmit": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "useDefineForClassFields": false,
    "experimentalDecorators": false,
    "forceConsistentCasingInFileNames": true,
    "noUnusedLocals": true,
    "noUnusedParameters": true
  },
  "include": ["web/**/*.ts"],
  "exclude": ["web/web_modules", "node_modules"]
}
